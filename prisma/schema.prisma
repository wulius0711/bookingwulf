generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  accentColor String?
  email            String?
  phone            String?
  bookingTermsUrl  String?
  privacyPolicyUrl String?
  isActive         Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Billing
  plan                   String    @default("starter") // starter | pro | business
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  subscriptionStatus     String    @default("inactive") // inactive | trialing | active | past_due | cancelled
  trialEndsAt            DateTime?

  // hungrywulf integration
  hungrywulfEnabled      Boolean   @default(false)
  hungrywulfRestaurantId String?
  hungrywulfSecret       String?

  // eventwulf integration
  eventwulfEnabled Boolean  @default(false)
  eventwulfOrgId   String?
  eventwulfSecret  String?

  settings        HotelSettings?
  settingsPresets HotelSettingsPreset[]
  widgetConfigs   WidgetConfig[]
  emailTemplates  EmailTemplate[]
  apartments      Apartment[]
  requests      Request[]
  adminUsers    AdminUser[]
  userHotels    AdminUserHotel[]
  blockedRanges BlockedRange[]
  extras            HotelExtra[]
  childPriceRanges  ChildPriceRange[]
  nukiConfig    NukiConfig?
  beds24Config  Beds24Config?
  auditLogs     AuditLog[]
  supportChats  SupportChatLog[]
}

model HotelSettings {
  id      Int   @id @default(autoincrement())
  hotelId Int   @unique
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  // 🔧 Feature Toggles
  showPrices        Boolean @default(true)
  allowMultiSelect  Boolean @default(false)
  showAmenities     Boolean @default(true)
  showExtrasStep    Boolean @default(true)
  showPhoneField    Boolean @default(true)
  showMessageField  Boolean @default(true)
  enableImageSlider    Boolean @default(true)
  enableLightbox       Boolean @default(true)
  instantBooking       Boolean @default(false)
  enableInstantBooking Boolean @default(false)
  hideRequestOption    Boolean @default(false)
  showUrgencySignals   Boolean @default(false)
  gapNightDiscount     Int?    // % discount for gap nights (null = disabled)
  gapNightMaxLength    Int?    // max gap length in nights to qualify

  urgencyThreshold       Int     @default(40)  // % free nights below which banner shows

  preArrivalEnabled      Boolean @default(false)
  preArrivalHouseRules   String?
  preArrivalReminderDays Int     @default(3)

  checkoutReminderEnabled Boolean @default(false)
  checkoutTime            String?
  checkoutReminderText    String?
  checkoutReminderSubject String?
  checkoutReminderBody    String?

  reviewRequestEnabled Boolean @default(false)
  reviewRequestDays    Int     @default(2)   // days after departure to send
  reviewRequestLink    String?              // Google Reviews URL
  reviewRequestSubject String?
  reviewRequestBody    String?

  // 🎨 Colors
  accentColor      String?  // Primary highlight
  backgroundColor  String?  // App background
  cardBackground   String?  // Card background
  textColor        String?  // Main text
  mutedTextColor   String?  // Secondary text (#666)
  borderColor      String?  // Borders / dividers

  // 💠 UI Shape
  cardRadius   Int?  // z.B. 8 / 12 / 16
  buttonRadius Int?  // optional getrennt
  buttonColor  String?

  // 🔤 Typography
  headlineFont       String?
  bodyFont           String?
  headlineFontSize   Int?
  bodyFontSize       Int?
  headlineFontWeight Int?
  bodyFontWeight     Int?
  headlineFontUrl    String?  // custom uploaded font (Business)
  bodyFontUrl        String?  // custom uploaded font (Business)

  // 💸 Dynamic Pricing
  lastMinuteDiscountPercent   Int @default(0)  // 0 = disabled
  lastMinuteDiscountDays      Int @default(7)
  occupancySurchargePercent   Int @default(0)  // 0 = disabled
  occupancySurchargeThreshold Int @default(70) // % occupancy to trigger surcharge

  // 🏛️ Ortstaxe / Kurtaxe
  ortstaxeMode              String   @default("off")  // "off" | "wien" | "custom"
  ortstaxePerPersonPerNight Decimal? @db.Decimal(10, 2)  // used in "custom" mode
  ortstaxeMinAge            Int?     // children below this age are exempt (null = all pay)

  // 🧾 Steuer / Buchhaltung
  taxRateRoom     Decimal? @db.Decimal(5, 2)  // MwSt.-Satz Zimmerpreis in % (z.B. 10.00)
  taxRateCleaning Decimal? @db.Decimal(5, 2)  // MwSt.-Satz Reinigung in % (z.B. 20.00)

  // 💳 Zahlungsarten
  bankTransferEnabled Boolean @default(false)
  paypalEnabled       Boolean @default(false)
  paypalClientId      String?
  paypalClientSecret  String?
  stripeEnabled         Boolean @default(false)
  stripePublishableKey  String?
  stripeSecretKey       String?

  // 💳 Anzahlung & Bankdaten
  depositEnabled      Boolean @default(false)
  depositType         String  @default("percent")  // "percent" | "fixed"
  depositValue        Float   @default(25)
  depositDueDays      Int     @default(7)
  bankAccountHolder   String?
  bankIban            String?
  bankBic             String?

  // 🔗 Mini-Widget
  miniWidgetTarget String?  // URL of the page where the full widget is embedded

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WidgetConfig {
  id      Int   @id @default(autoincrement())
  hotelId Int
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  slug String  // z.B. "anfrage" oder "buchung"
  name String  // Anzeigename im Admin

  showPrices           Boolean @default(true)
  showAmenities        Boolean @default(true)
  showExtrasStep       Boolean @default(true)
  showPhoneField       Boolean @default(true)
  showMessageField     Boolean @default(true)
  enableImageSlider    Boolean @default(true)
  enableInstantBooking Boolean @default(false)
  hideRequestOption    Boolean @default(false)
  showUrgencySignals   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, slug])
}

model HotelSettingsPreset {
  id      Int   @id @default(autoincrement())
  hotelId Int
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name             String
  accentColor      String?
  backgroundColor  String?
  cardBackground   String?
  textColor        String?
  mutedTextColor   String?
  borderColor      String?
  cardRadius       Int?
  buttonRadius     Int?
  buttonColor      String?

  createdAt DateTime @default(now())
}

model Apartment {
  id      Int   @id @default(autoincrement())
  hotelId Int
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  // Core
  name String
  slug String

  // Capacity
  maxAdults   Int @default(2)
  maxChildren Int @default(0)

  // Pricing
  basePrice   Float?
  cleaningFee Float?

  // Compact Content
  size     Int?
  bedrooms Int?
  view     String?

  // Meta
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // LONG CONTENT
  description String?
  amenities   String[] @default([])

  // Nuki
  nukiSmartlockId String?

  // Relations
  images        ApartmentImage[]
  blockedRanges BlockedRange[]
  priceSeasons  PriceSeason[]
  icalFeeds       IcalFeed[]
  beds24Mapping   Beds24ApartmentMapping?

  @@unique([hotelId, slug])
}

model IcalFeed {
  id          Int       @id @default(autoincrement())
  apartmentId Int
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  name        String    // e.g. "Airbnb", "Booking.com"
  url         String
  lastSyncAt  DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([apartmentId])
}

model ApartmentImage {
  id          Int      @id @default(autoincrement())
  apartmentId Int
  imageUrl    String
  altText     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId])
}

model PriceSeason {
  id            Int      @id @default(autoincrement())
  apartmentId   Int
  name          String?
  startDate     DateTime
  endDate       DateTime
  pricePerNight Float
  minStay       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, startDate, endDate])
}

model BlockedRange {
  id      Int    @id @default(autoincrement())
  hotelId Int? // ← OPTIONAL
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  apartmentId Int?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  type      String
  note      String?
  createdAt DateTime @default(now())

  @@index([hotelId, startDate, endDate])
  @@index([apartmentId, startDate, endDate])
}

model Request {
  id      Int    @id @default(autoincrement())
  hotelId Int? // ← OPTIONAL
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  arrival              DateTime
  departure            DateTime
  nights               Int
  adults               Int
  children             Int      @default(0)
  selectedApartmentIds String
  salutation           String
  firstname            String?
  lastname             String
  email                String
  country              String
  message              String?
  paymentMethod        String?
  paypalOrderId        String?
  newsletter           Boolean  @default(false)
  status               String   @default("new")
  language             String   @default("de") // de | en | it
  extrasJson           Json?
  pricingJson          Json?    // snapshot: { apartments: {name,total,cleaning}[], ortstaxe, total }
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  nukiCode    String?
  nukiAuthIds String?

  checkinToken           String?   @unique
  checkinCompletedAt     DateTime?
  checkinArrivalTime     String?
  checkinNotes           String?
  checkinReminderSentAt  DateTime?
  checkinBirthdate       String?
  checkinNationality     String?
  checkinDocNumber       String?

  checkoutReminderSentAt DateTime?
  reviewRequestSentAt    DateTime?

  messages RequestMessage[]

  @@index([hotelId])
  @@index([hotelId, status])
  @@index([arrival, departure])
}

model RequestMessage {
  id        Int      @id @default(autoincrement())
  requestId Int
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    String   // 'hotel' | 'guest'
  body      String
  createdAt DateTime @default(now())

  @@index([requestId])
}

model HotelExtra {
  id          Int      @id @default(autoincrement())
  hotelId     Int
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  key         String
  type        String   @default("extra") // extra | insurance
  billingType String   // per_night | per_person_per_night | per_stay | per_person_per_stay
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  description String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([hotelId, key])
}

model AdminUser {
  id      Int    @id @default(autoincrement())
  hotelId Int?
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  email        String   @unique
  passwordHash String
  role         String   @default("hotel_admin")
  isActive     Boolean  @default(true)

  resetToken     String?   @unique
  resetExpiresAt DateTime?

  isEmailVerified        Boolean   @default(false)
  emailVerifyToken       String?   @unique
  emailVerifyTokenExpiresAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userHotels AdminUserHotel[]
}

model AdminUserHotel {
  userId  Int
  hotelId Int
  user    AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel   Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@id([userId, hotelId])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  hotelId   Int
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  type      String   // request_guest | booking_guest | request_hotel
  subject   String
  greeting  String?
  body      String
  signoff   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, type])
}

model NukiConfig {
  id        Int      @id @default(autoincrement())
  hotelId   Int      @unique
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  apiToken  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Beds24Config {
  id           Int      @id @default(autoincrement())
  hotelId      Int      @unique
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  refreshToken String
  isEnabled    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Beds24ApartmentMapping {
  id            Int       @id @default(autoincrement())
  apartmentId   Int       @unique
  apartment     Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  beds24RoomId  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  hotelId   Int
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  changedAt DateTime @default(now())

  @@index([hotelId, changedAt])
}

model ChildPriceRange {
  id            Int      @id @default(autoincrement())
  hotelId       Int
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  label         String?
  minAge        Int
  maxAge        Int
  pricePerNight Decimal  @db.Decimal(10, 2)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([hotelId])
}

model OutreachLead {
  id         Int       @id @default(autoincrement())
  betrieb    String
  inhaber    String?
  email      String?
  phone      String?
  kontaktPer String?
  region     String?
  website    String?
  // neu | gesendet | follow-up | geantwortet | demo | kein-interesse | abgeschlossen
  status     String    @default("neu")
  sentAt     DateTime?
  followUpAt DateTime?
  notes      String?
  nextStep   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SupportChatLog {
  id        Int      @id @default(autoincrement())
  hotelId   Int?
  question  String
  answer    String
  category  String   @default("sonstiges")
  isSuperAdmin Boolean @default(false)
  createdAt DateTime @default(now())

  hotel     Hotel?   @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([createdAt])
  @@index([category])
}


model AdminFeedback {
  id         Int      @id @default(autoincrement())
  hotelId    Int?
  hotelName  String?
  userEmail  String?
  message    String
  page       String?
  screenshot String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
