generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  accentColor String?
  email            String?
  phone            String?
  bookingTermsUrl  String?
  privacyPolicyUrl String?
  isActive         Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Billing
  plan                   String    @default("starter") // starter | pro | business
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  subscriptionStatus     String    @default("inactive") // inactive | trialing | active | past_due | cancelled
  trialEndsAt            DateTime?

  settings        HotelSettings?
  settingsPresets HotelSettingsPreset[]
  emailTemplates  EmailTemplate[]
  apartments      Apartment[]
  requests      Request[]
  adminUsers    AdminUser[]
  userHotels    AdminUserHotel[]
  blockedRanges BlockedRange[]
  extras        HotelExtra[]
}

model HotelSettings {
  id      Int   @id @default(autoincrement())
  hotelId Int   @unique
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  // 🔧 Feature Toggles
  showPrices        Boolean @default(true)
  allowMultiSelect  Boolean @default(false)
  showAmenities     Boolean @default(true)
  showExtrasStep    Boolean @default(true)
  showPhoneField    Boolean @default(true)
  showMessageField  Boolean @default(true)
  enableImageSlider    Boolean @default(true)
  enableLightbox       Boolean @default(true)
  instantBooking       Boolean @default(false)
  enableInstantBooking Boolean @default(false)

  // 🎨 Colors
  accentColor      String?  // Primary highlight
  backgroundColor  String?  // App background
  cardBackground   String?  // Card background
  textColor        String?  // Main text
  mutedTextColor   String?  // Secondary text (#666)
  borderColor      String?  // Borders / dividers

  // 💠 UI Shape
  cardRadius   Int?  // z.B. 8 / 12 / 16
  buttonRadius Int?  // optional getrennt

  // 🧩 Optional später
  // buttonStyle   String? // 'filled' | 'outline'
  // fontFamily    String?
  // spacingScale  String? // 'tight' | 'normal' | 'airy'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HotelSettingsPreset {
  id      Int   @id @default(autoincrement())
  hotelId Int
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name             String
  accentColor      String?
  backgroundColor  String?
  cardBackground   String?
  textColor        String?
  mutedTextColor   String?
  borderColor      String?
  cardRadius       Int?
  buttonRadius     Int?

  createdAt DateTime @default(now())
}

model Apartment {
  id      Int   @id @default(autoincrement())
  hotelId Int
  hotel   Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  // Core
  name String
  slug String

  // Capacity
  maxAdults   Int @default(2)
  maxChildren Int @default(0)

  // Pricing
  basePrice   Float?
  cleaningFee Float?

  // Compact Content
  size     Int?
  bedrooms Int?
  view     String?

  // Meta
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // LONG CONTENT
  description String?
  amenities   String[] @default([])

  // Relations
  images        ApartmentImage[]
  blockedRanges BlockedRange[]
  priceSeasons  PriceSeason[]
  icalFeeds     IcalFeed[]

  @@unique([hotelId, slug])
}

model IcalFeed {
  id          Int       @id @default(autoincrement())
  apartmentId Int
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  name        String    // e.g. "Airbnb", "Booking.com"
  url         String
  lastSyncAt  DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ApartmentImage {
  id          Int      @id @default(autoincrement())
  apartmentId Int
  imageUrl    String
  altText     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model PriceSeason {
  id            Int      @id @default(autoincrement())
  apartmentId   Int
  name          String?
  startDate     DateTime
  endDate       DateTime
  pricePerNight Float
  minStay       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model BlockedRange {
  id      Int    @id @default(autoincrement())
  hotelId Int? // ← OPTIONAL
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  apartmentId Int?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  type      String
  note      String?
  createdAt DateTime @default(now())
}

model Request {
  id      Int    @id @default(autoincrement())
  hotelId Int? // ← OPTIONAL
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  arrival              DateTime
  departure            DateTime
  nights               Int
  adults               Int
  children             Int      @default(0)
  selectedApartmentIds String
  salutation           String
  firstname            String?
  lastname             String
  email                String
  country              String
  message              String?
  newsletter           Boolean  @default(false)
  status               String   @default("new")
  extrasJson           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  messages RequestMessage[]
}

model RequestMessage {
  id        Int      @id @default(autoincrement())
  requestId Int
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    String   // 'hotel' | 'guest'
  body      String
  createdAt DateTime @default(now())
}

model HotelExtra {
  id          Int      @id @default(autoincrement())
  hotelId     Int
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  key         String
  type        String   @default("extra") // extra | insurance
  billingType String   // per_night | per_person_per_night | per_stay | per_person_per_stay
  price       Decimal  @db.Decimal(10, 2)
  linkUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([hotelId, key])
}

model AdminUser {
  id      Int    @id @default(autoincrement())
  hotelId Int?
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  email        String   @unique
  passwordHash String
  role         String   @default("hotel_admin")
  isActive     Boolean  @default(true)

  resetToken     String?   @unique
  resetExpiresAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userHotels AdminUserHotel[]
}

model AdminUserHotel {
  userId  Int
  hotelId Int
  user    AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel   Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@id([userId, hotelId])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  hotelId   Int
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  type      String   // request_guest | booking_guest | request_hotel
  subject   String
  greeting  String?
  body      String
  signoff   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, type])
}
